<?xml version="1.0" encoding="utf-8"?>

<Page
    x:Class="MarketPlace924.View.BuyerProfileView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:MarketPlace924.View"

    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Grid RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="150" />
            <RowDefinition Height="450" />
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" RowDefinitions="Auto, *">
            <!-- Main Content (e.g., Title and Profile) -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="Buyer Profile" FontSize="42" FontWeight="Bold" TextAlignment="Center"
                           Foreground="#0D47A1" FontFamily="Segoe UI Black" />
                <TextBlock Text="View and edit your profile details below" FontSize="24" Margin="0,5"
                           TextAlignment="Center" Foreground="#1976D2" FontFamily="Segoe UI Semibold" />
            </StackPanel>

            <!-- TODO:Badge System in the Top-Right Corner -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10">
                <!-- Profile Picture -->
                <Image Source="ms-appx:///Assets/bronze-badge.png" Width="50" Height="50"
                       HorizontalAlignment="Right" VerticalAlignment="Top" />

                <!-- Badge with Progress Bar -->
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Orientation="Vertical"
                            Spacing="5">
                    <!-- Badge Text -->
                    <TextBlock Text="Level 1" FontSize="14" Foreground="#1976D2"
                               FontFamily="Segoe UI Semibold" />

                    <!-- Progress Bar -->
                    <ProgressBar Width="150" Height="20" Minimum="0" Maximum="100" Value="60"
                                 Background="#e0e0e0" Foreground="#1976D2" />
                </StackPanel>
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="1">
            <Grid ColumnSpacing="80">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="30" Grid.Column="0">

                    <TextBlock Text="Personal Information" Style="{StaticResource PrimaryLabel}" />

                    <!-- First Name -->
                    <StackPanel>
                        <TextBlock Text="First Name" Style="{StaticResource PrimaryLabel}" />
                        <TextBox Text="{x:Bind ViewModel.Buyer.FirstName, Mode=TwoWay}"
                                 Style="{StaticResource PrimaryTextBox}" />
                    </StackPanel>

                    <!-- Last Name -->
                    <StackPanel>
                        <TextBlock Text="Last Name" Style="{StaticResource PrimaryLabel}" />
                        <TextBox Text="{x:Bind ViewModel.Buyer.LastName, Mode=TwoWay}"
                                 Style="{StaticResource PrimaryTextBox}" />
                    </StackPanel>

                    <!-- Email -->
                    <StackPanel>
                        <TextBlock Text="Email" Style="{StaticResource PrimaryLabel}" />
                        <TextBox Text="{x:Bind ViewModel.Buyer.Email, Mode=TwoWay}"
                                 Style="{StaticResource PrimaryTextBox}" />
                    </StackPanel>

                    <!-- Phone -->
                    <StackPanel>
                        <TextBlock Text="Phone" Style="{StaticResource PrimaryLabel}" />
                        <TextBox Text="{x:Bind ViewModel.Buyer.PhoneNumber, Mode=TwoWay}"
                                 Style="{StaticResource PrimaryTextBox}" />
                    </StackPanel>

                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Billing Address" Style="{StaticResource PrimaryLabel}" />
                    <local:BuyerAddressFormView ViewModel="{x:Bind ViewModel.BillingAddress, Mode=OneWay}"></local:BuyerAddressFormView>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Shipping Address"
                                   Style="{StaticResource PrimaryLabel}" />
                        <CheckBox Grid.Column="1" Content=" Same Address as Billing"
                                  IsChecked="{x:Bind ViewModel.ShippingAddressDisabled, Mode=TwoWay}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>

                    <local:BuyerAddressFormView ViewModel="{x:Bind ViewModel.ShippingAddress, Mode=OneWay}"
                                                IsEnabled="{x:Bind ViewModel.ShippingAddressEnabled, Mode=OneWay}">
                    </local:BuyerAddressFormView>
                </StackPanel>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Save" Click="{x:Bind ViewModel.SaveInfo}"
                        Style="{StaticResource PrimaryButton}" />
                <Button Grid.Column="1" Content="Reset" Click="{x:Bind ViewModel.ResetInfo}"
                        Style="{StaticResource PrimaryButton}" />
            </Grid>
        </StackPanel>
        <Grid Grid.Row="3" Margin="0,30,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*" /> <!-- Wishlist -->
                <ColumnDefinition Width="1.5*" /> <!-- Description & Sync Toggle -->
            </Grid.ColumnDefinitions>

            <!-- Wishlist Panel -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Manage Your Wishlist" Style="{StaticResource PrimaryLabel}" FontSize="24" />
                <TextBlock
                    Text="Easily add, remove, or move items to your cart. Enable 'Family-Synced' mode to share with family members."
                    FontSize="14" Foreground="Gray" TextWrapping="Wrap" Margin="0,5,0,0" />

                <!-- TODO Wishlist Controls (Inline Buttons + Sync Switch) -->
                <Grid ColumnSpacing="10" RowSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>


                    <TextBox Grid.Column="0" Width="200" Height="40" PlaceholderText="Search products..."
                             Style="{StaticResource PrimaryTextBox}" />

                    <!-- Search Button -->
                    <Button Grid.Column="1" Content="Search" Style="{StaticResource PrimaryButton}"
                            Width="100" Height="50" />

                    <ComboBox Grid.Column="2" Width="170" Height="50"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Filter" />
                        <ComboBoxItem Content="Sort by: Ascending Price" />
                        <ComboBoxItem Content="Sort by: Descending Price" />
                    </ComboBox>

                    <!-- Family Sync Toggle -->
                    <ToggleSwitch Grid.Column="3" Header="Family-Synced"
                                  OffContent="Off" OnContent="On" />
                </Grid>

                <!-- TODO Wishlist Items -->
                <Border Background="White" Padding="15" CornerRadius="10" BorderBrush="#1565C0"
                        BorderThickness="2" Margin="0,15,0,0">
                    <ScrollViewer Height="250" VerticalScrollBarVisibility="Auto">
                        <ItemsControl>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapGrid Orientation="Horizontal" MaximumRowsOrColumns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderThickness="2" BorderBrush="#1976D2" Padding="10"
                                            Margin="5" CornerRadius="8" Background="White"
                                            Width="180" Height="200">
                                        <StackPanel HorizontalAlignment="Center">
                                            <!-- Mock Image -->
                                            <Image Source="ms-appx:///Assets/bronze-badge.png" Width="80" Height="80"
                                                   Stretch="Uniform" Margin="0,5,0,5" />

                                            <!-- Item Name -->
                                            <TextBlock Text="Sample Item" FontSize="16" FontWeight="Bold"
                                                       Foreground="#0D47A1" TextAlignment="Center" />

                                            <!-- Price -->
                                            <TextBlock Text="$19.99" FontSize="14" Foreground="Gray"
                                                       TextAlignment="Center" Margin="0,3,0,0" />

                                            <!-- Action Buttons -->
                                            <Grid ColumnSpacing="5" Margin="5,8,5,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Content="🗑" Width="35" Height="30"
                                                        ToolTipService.ToolTip="Remove" />
                                                <Button Grid.Column="1" Content="🛒" Width="35" Height="30"
                                                        ToolTipService.ToolTip="Add to Cart" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

            </StackPanel>

            <!-- TODO Family sync-->
            <StackPanel Grid.Column="1" Margin="15,0,0,0">
                <TextBlock Text="Manage Your Family Sync" Style="{StaticResource PrimaryLabel}"
                           FontSize="24" />
                <TextBlock
                    Text="Easily sync and unsync. Enable 'Family-Synced' mode to share with family members."
                    FontSize="14" Foreground="Gray" TextWrapping="Wrap" Margin="0,5,0,0" />

                <Border Background="White" Padding="15" CornerRadius="10" BorderBrush="#1565C0"
                        BorderThickness="2" Margin="0,15,0,0">
                    <ScrollViewer Height="250" VerticalScrollBarVisibility="Auto">
                        <ItemsControl>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapGrid Orientation="Horizontal" MaximumRowsOrColumns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderThickness="2" BorderBrush="#1976D2" Padding="10"
                                            Margin="5" CornerRadius="8" Background="White"
                                            Width="160" Height="120">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock FontSize="16"
                                                       FontWeight="Bold"
                                                       Foreground="#0D47A1" TextAlignment="Center" />
                                            <TextBlock FontSize="12"
                                                       Foreground="Gray"
                                                       TextAlignment="Center" TextWrapping="Wrap"
                                                       Margin="0,3,0,0" />
                                            <!-- Action Buttons -->
                                            <Grid ColumnSpacing="5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Content="🗑"
                                                        Width="35" Height="30" />
                                                <Button Grid.Column="1" Content="🛒"

                                                        Width="35" Height="30" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Grid>


    </Grid>

</Page>